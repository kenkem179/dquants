# ---- Data (large / regenerable) ----
data/btcusd/
data/raw/
data/processed/
data/features/
data/labels/
*.csv
*.parquet
*.duckdb
*.feather

# ---- Research artifacts ----
research/optimization/*.log
backtests/results/

# MT5-run parity reference artifacts are handoff-critical SAMPLE DATA — keep them tracked.
# (the broad *.csv above would otherwise hide them, silently breaking the diff tools after a
#  handoff/clone. Don't rely on `git add -f` — that's how they go missing.)
!research/**/mt5_runs/**/*.csv
# ...EXCEPT the giant per-bar trace dumps (80-280MB each) — those stay ignored (kept as .gz or
#  regenerated on demand). Re-ignore by name so only the small artifacts (trades/realtrace/gate) track.
research/**/mt5_runs/**/trace.csv
research/**/mt5_runs/**/parity_trace.csv
reports/*.html
research/notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
.env
.ipynb_checkpoints/
.pytest_cache/
.ruff_cache/

# ---- C++ build ----
cpp_core/build/
*.o
*.a
*.out
*.dSYM/
# generated parity bridge artifacts (regenerable via tools/export_bars.py + parity_driver)
cpp_core/tools/bars_*.csv
cpp_core/tools/parity_cpp_*.csv
# but DO commit the frozen golden parity fixtures (small, test regression guard)
!cpp_core/tests/golden/
!cpp_core/tests/golden/*.csv

# ---- MT5 compiled ----
*.ex5

# ---- OS / editor ----
.DS_Store
.idea/
.vscode/
research/**/mt5_runs/**/run.log
