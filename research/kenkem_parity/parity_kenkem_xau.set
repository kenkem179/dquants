; ADX_LEN / RSI_LEN removed: EA hardcodes them to 14 (not inputs); engine now ignores any override.
ENABLE_E1_ENTRIES=false
ENABLE_E2_ENTRIES=false
ENABLE_E4_ENTRIES=false
ENABLE_E5_ENTRIES=true
ENABLE_TREND_QUALITY_GATES=true
E5_RR_SIDEWAY=0.8064
